# Copy this file to .env.local and fill in your values.
# Get Supabase values from: https://supabase.com/dashboard/project/_/settings/api

# Project URL (required for DB connection)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key – required for app to read/write inventory, transactions, quick scans
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key – server-only; required for Settings → user management (list/create/update profiles via /api/admin).
# Uncomment and paste from Supabase → Project Settings → API → service_role (secret). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Microsoft sign-in: Supabase Auth → Providers → Azure.
# - Entra app registration: keep "single tenant" for an internal-only app.
# - In Supabase Azure settings, set Tenant URL to (NOT /common):
#     https://login.microsoftonline.com/<YOUR_ENTRA_TENANT_ID>
# - Entra redirect URL: https://<YOUR_PROJECT_REF>.supabase.co/auth/v1/callback
# - Supabase → Authentication → URL Configuration: site URL + http://localhost:3000/auth/callback (and prod)
